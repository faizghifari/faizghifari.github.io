---
import SocialLinks from './SocialLinks.astro';

const currentYear = new Date().getFullYear();

const academicProfiles = [
  {
    name: 'Google Scholar',
    url: 'https://scholar.google.com/citations?user=ZH3qXdUAAAAJ&hl=en&authuser=1',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 24a7.42 7.42 0 0 1-9.6-8.8A7.42 7.42 0 0 1 12 24zM10.2 7.6h3.8v1.9h-3.8V7.6zm0 3.8h3.8v1.9h-3.8v-1.9zm0 3.8h3.8v1.9h-3.8v-1.9z"/></svg>`,
  },
  {
    name: 'Semantic Scholar',
    url: 'https://www.semanticscholar.org/author/Faiz-Ghifari-Haznitrama/2287841290',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>`,
  },
  {
    name: 'ACL Anthology',
    url: 'https://aclanthology.org/people/faiz-ghifari-haznitrama/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6H6zm7 0v5a1 1 0 0 1-1 1H9V2h4zm-5 9h8v2H8v-2zm0 4h5v2H8v-2z"/></svg>`,
  },
  {
    name: 'OpenReview',
    url: 'https://openreview.net/profile?id=%7EFaiz_Ghifari_Haznitrama1',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>`,
  },
  {
    name: 'DBLP',
    url: 'https://dblp.org/pid/371/3974',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>`,
  },
  {
    name: 'ORCID',
    url: 'https://orcid.org/0009-0005-0342-9261',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0a12 12 0 1 0 0 24 12 12 0 0 0 0-24zm-1.8 7.2h1.6v8.4h-1.6V7.2zm3.2 0h1.6v1.2c.4-.8 1.2-1.6 2.4-1.6 2.4 0 3.2 1.6 3.2 4v5.6h-1.6V12c0-1.6-.4-2.8-2-2.8s-2.4 1.2-2.4 2.8v3.6h-1.6V7.2zM6 6.4c0 .8-.8 1.2-1.6 1.2S2.8 7.2 2.8 6.4 3.6 5.2 4.4 5.2s1.6.4 1.6 1.2zM4.8 8h1.6v7.6H4.8V8z"/></svg>`,
  },
];
---

<footer class="border-t border-gray-200 dark:border-slate-800 mt-auto transition-colors">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <!-- Academic Profile Icons -->
    <div class="flex items-center justify-center gap-5 mb-5">
      {academicProfiles.map(profile => (
        <a
          href={profile.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline"
          title={profile.name}
        >
          <span set:html={profile.icon} class="inline-block w-5 h-5" />\
        </a>
      ))}
    </div>

    <div class="flex flex-col items-center text-center gap-4">
      <!-- Name & copyright — centered -->
      <div>
        <p class="text-sm font-medium text-gray-900 dark:text-white">
          Faiz Ghifari Haznitrama
        </p>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          &copy; {currentYear} &middot; Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="no-underline">Astro</a> &amp; <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="no-underline">Tailwind CSS</a>
        </p>
      </div>

      <!-- Social links -->
      <SocialLinks size="sm" />
    </div>
  </div>
</footer>

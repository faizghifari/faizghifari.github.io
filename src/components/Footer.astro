---

<footer class="border-t border-gray-200 dark:border-slate-800 mt-auto transition-colors">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <!-- Academic Profile Icons -->
    <div class="flex items-center justify-center gap-5 mb-5">
      {academicProfiles.map(profile => (
        <a
          href={profile.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline"
          title={profile.name}
        >
          <span set:html={profile.icon} />
        </a>
      ))}
    </div>

    <div class="text-center">
      <div class="mb-4">
        <p class="text-sm font-medium text-gray-900 dark:text-white">
          Faiz Ghifari Haznitrama
        </p>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          &copy; {currentYear} &middot; Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="no-underline">Astro</a> &amp; <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="no-underline">Tailwind CSS</a>
        </p>
      </div>
    </div>
  </div>
</footer>

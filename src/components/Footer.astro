---
import SocialLinks from './SocialLinks.astro';

const currentYear = new Date().getFullYear();

const academicProfiles = [
  {
    name: 'Google Scholar',
    url: 'https://scholar.google.com/citations?user=ZH3qXdUAAAAJ&hl=en&authuser=1',
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 24a7.42 7.42 0 01-9.6-8.8A7.42 7.42 0 0112 24zM10.2 7.6h3.8v1.9h-3.8V7.6zm0 3.8h3.8v1.9h-3.8v-1.9zm0 3.8h3.8v1.9h-3.8v-1.9z"/></svg>`,
  },
  {
    name: 'Semantic Scholar',
    url: 'https://www.semanticscholar.org/author/Faiz-Ghifari-Haznitrama/2287841290',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13M7.554 7.554l8.892 8.892M16.446 7.554l-8.892 8.892"/></svg>`,
  },
  {
    name: 'ACL Anthology',
    url: 'https://aclanthology.org/people/faiz-ghifari-haznitrama/',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13M7.554 7.554l8.892 8.892M16.446 7.554l-8.892 8.892"/></svg>`,
  },
  {
    name: 'OpenReview',
    url: 'https://openreview.net/profile?id=%7EFaiz_Ghifari_Haznitrama1',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  },
  {
    name: 'DBLP',
    url: 'https://dblp.org/pid/371/3974',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13M7.554 7.554l8.892 8.892M16.446 7.554l-8.892 8.892"/></svg>`,
  },
  {
    name: 'ORCID',
    url: 'https://orcid.org/0009-0005-0342-9261',
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.629 0 1.136.507 1.136 1.136s-.507 1.136-1.136 1.136S6.233 6.149 6.233 5.517c0-.621.516-1.139 1.136-1.139zM7.455 6.933h1.227v6.826H5.84V9.88c0-1.054.945-1.937 1.937-1.937.165 0 .325.016.48.054v1.293c-.125-.033-.25-.049-.378-.049-.629 0-1.136.507-1.136 1.136v1.335h2.81V6.933zm5.423 0h-1.227v6.826H9.84V9.88c0-1.054.945-1.937 1.937-1.937.165 0 .325.016.48.054v1.293c-.125-.033-.25-.049-.378-.049-.629 0-1.136.507-1.136 1.136v1.335h2.81V6.933zm1.613 0h-1.227v6.826h-1.842V6.933h3.07v1.227h-1.842v1.335h1.464v1.227h-1.464v1.81h1.842v1.227h-3.07V6.933h1.227v1.227h1.842V6.933z"/></svg>`,
  },
];
---

<footer class="border-t border-gray-200 dark:border-slate-800 mt-auto transition-colors">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <!-- Academic Profile Icons -->
    <div class="flex items-center justify-center gap-5 mb-5">
      {academicProfiles.map(profile => (
        <a
          href={profile.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline"
          title={profile.name}
        >
          <span set:html={profile.icon} />
        </a>
      ))}
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Left: Name & copyright -->
      <div class="text-center md:text-left">
        <p class="text-sm font-medium text-gray-900 dark:text-white">
          Faiz Ghifari Haznitrama
        </p>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          &copy; {currentYear} &middot; Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="no-underline">Astro</a> &amp; <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="no-underline">Tailwind CSS</a>
        </p>
      </div>

      <!-- Right: Social links -->
      <SocialLinks size="sm" />
    </div>
  </div>
</footer>

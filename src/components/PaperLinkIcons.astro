---
// Paper link icons component
// Usage: <PaperLinkIcons links={{ pdf: 'url', arxiv: 'url', github: 'url', doi: 'url', acl: 'url' }} />

interface Props {
  links: Record<string, string>;
}

const { links } = Astro.props;

const iconMap: Record<string, { label: string; svg: string }> = {
  pdf: {
    label: 'PDF',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-4"/><path d="M8 16l2 2 4-4"/></svg>`,
  },
  arxiv: {
    label: 'arXiv',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-.051 4.667c.92 0 1.667.747 1.667 1.667s-.747 1.667-1.667 1.667-1.667-.747-1.667-1.667.747-1.667 1.667-1.667zm3.067 12.667H8.884V11h.737l.889 2.511h.031L11.44 11h.737v6.334h-.711V11h-.031l-1.174 3.333h-.527L9.54 11h-.031V17.334H8.807V11H7.4v-1.111h4.611V11h1.4zm4.611 0h-1.4V11h-1.111v-1.111h3.922V11h-1.111v6.334z"/></svg>`,
  },
  github: {
    label: 'GitHub',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
  },
  doi: {
    label: 'DOI',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M7 10h4"/><path d="M7 14h8"/><path d="M15 10h2"/></svg>`,
  },
  acl: {
    label: 'ACL Anthology',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M12 6v6"/><path d="M9 9h6"/></svg>`,
  },
  openreview: {
    label: 'OpenReview',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/><path d="M12 8v4"/><path d="M8 16l2-2"/></svg>`,
  },
  demo: {
    label: 'Demo',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>`,
  },
};
---

<div class="flex flex-wrap gap-3">
  {Object.entries(links).map(([key, url]) => {
    const iconData = iconMap[key];
    if (!iconData) return null;
    return (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-gray-500 hover:text-indigo-600 dark:text-gray-400 dark:hover:text-indigo-400 transition-colors no-underline"
        title={iconData.label}
      >
        <span set:html={iconData.svg} />
        <span class="text-xs font-medium">{iconData.label}</span>
      </a>
    );
  })}
</div>

  },
  {
    label: 'Google Scholar',
    href: 'https://scholar.google.com/citations?user=ZH3qXdUAAAAJ&hl=en&authuser=1',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479" />`,
  },
  {
    label: 'ORCID',
    href: 'https://orcid.org/0009-0005-0342-9261',
    icon: `<path d="M22.017 9.319a1.468 1.468 0 00-.695-.756c-.585-.3-1.185-.3-1.77 0-.29.15-.54.375-.72.66-.18.285-.27.6-.27.93 0 .33.09.645.27.93.18.285.435.51.72.66.585.3 1.185.3 1.77 0 .29-.15.54-.375.72-.66.18-.285.27-.6.27-.93 0-.33-.09-.645-.27-.93l-.825-.234zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1.005 14.575c-.72 0-1.305-.27-1.755-.81-.45-.54-.675-1.2-.675-1.98 0-.78.225-1.44.675-1.98.45-.54 1.035-.81 1.755-.81.72 0 1.305.27 1.755.81.45.54.675 1.2.675 1.98 0 .78-.225 1.44-.675 1.98-.45.54-1.035.81-1.755.81z" />`,
  },
  {
    label: 'Semantic Scholar',
    href: 'https://www.semanticscholar.org/author/Faiz-Ghifari-Haznitrama/2287841290',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />`,

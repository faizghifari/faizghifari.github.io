---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="section">
    <div class="container-narrow text-center">
      <h1 class="text-8xl font-bold text-indigo-600 dark:text-indigo-400 mb-4">404</h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">Page not found</p>
      <a href="/" class="btn-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>

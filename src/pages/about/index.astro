---
import BaseLayout from '../../layouts/BaseLayout.astro';

const education = [
  {
    year: '2024 — Present',
    degree: 'Ph.D. in Computer Science',
    institution: 'Korea Advanced Institute of Science and Technology (KAIST)',
    detail: 'UILab — Research in multilingual NLP, reasoning under uncertainty, and human-centered AI.',
  },
  {
    year: '2021 — 2023',
    degree: 'M.Sc. in Computer Science',
    institution: 'Korea Advanced Institute of Science and Technology (KAIST)',
    detail: 'Master of Computer Science at KAIST, School of Computing.',
  },
  {
    year: '2015 — 2019',
    degree: 'B.Sc. in Informatics',
    institution: 'Institut Teknologi Bandung (ITB)',
    detail: 'Studied computer science with a focus on artificial intelligence and natural language processing.',
  },
];

const researchInterests = [
  {
    title: 'Multilingual NLP',
    description: 'Building language technologies that work well across diverse languages, especially low-resource ones. Bridging the gap between high-resource and under-resolved linguistic communities.',
    icon: '🌍',
  },
  {
    title: 'Reasoning Under Uncertainty',
    description: 'Developing models that can reason effectively when information is incomplete, ambiguous, or noisy — closer to how humans actually think.',
    icon: '🧠',
  },
  {
    title: 'Human-Centered AI',
    description: 'Designing AI systems that are transparent, accountable, and genuinely useful to the people they serve. Technology should empower, not replace.',
    icon: '🤝',
  },
  {
    title: 'Machine Translation',
    description: 'Improving automatic translation quality for under-resolved language pairs, making cross-lingual communication more accessible and equitable.',
    icon: '🔄',
  },
];
---

<BaseLayout
  title="About Me — Faiz Ghifari Haznitrama"
  description="Learn more about Faiz Ghifari Haznitrama — background, education, research interests, and skills."
>
  <!-- Hero / Intro Section -->
  <section class="section">
    <div class="container-narrow">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-12">
        <!-- Profile Photo -->
        <div class="flex-shrink-0">
          <img
            src="/profile-square.jpg"
            alt="Faiz Ghifari Haznitrama"
            class="w-36 h-36 md:w-44 md:h-44 rounded-full object-cover border-4 border-white dark:border-slate-800 shadow-lg"
            loading="eager"
          />
        </div>

        <!-- Bio -->
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">
            Hi, I'm Faiz 👋
          </h1>
          <p class="text-lg text-indigo-600 dark:text-indigo-400 font-medium mb-4">
            Ph.D. Student at UILab, KAIST
          </p>
          <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-4">
            I'm an Indonesian researcher currently based in Daejeon, South Korea, pursuing my doctorate at the
            <span class="font-medium">Korea Advanced Institute of Science and Technology (KAIST)</span>.
            I work in the <span class="font-medium">UILab</span>, where I explore how language models can better
            understand, reason, and communicate across diverse linguistic and cultural contexts.
          </p>
          <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-4">
            My journey into NLP started with a fascination for how language shapes the way we think and connect
            with each other. Growing up in Indonesia — a country with over 700 living languages — I saw firsthand
            how technology can either bridge or widen gaps between communities. That experience drives my research
            toward making AI more inclusive and accessible for everyone, not just speakers of high-resource languages.
          </p>
          <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
            When I'm not running experiments or writing papers, you'll find me exploring the food scene in Daejeon,
            reading sci-fi, or catching up on the latest AI papers over a cup of coffee.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Education Timeline -->
  <section class="section pb-6 bg-gray-50 dark:bg-slate-800/50 transition-colors">
    <div class="container-narrow">
      <h2 class="section-title">Education</h2>
      <div class="relative">
        {/* Vertical line */}
        <div class="absolute left-[15px] md:left-0 top-0 bottom-0 w-px bg-gray-200 dark:bg-slate-700 hidden md:block" />

        {education.map((item, i) => (
          <div class="relative flex gap-6 pb-10 last:pb-0">
            {/* Dot */}
            <div class="hidden md:flex flex-col items-center">
              <div class="timeline-dot mt-1.5" />
            </div>

            {/* Mobile dot — inline */}
            <div class="md:hidden flex-shrink-0">
              <div class="timeline-dot mt-1.5" />
            </div>

            {/* Content */}
            <div class="flex-1">
              <div class="card">
                <span class="tag mb-2 inline-block">{item.year}</span>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{item.degree}</h3>
                <p class="text-indigo-600 dark:text-indigo-400 font-medium text-sm mb-2">{item.institution}</p>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.detail}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Research Interests -->
  <section class="section pb-6">
    <div class="container-wide">
      <h2 class="section-title text-center">Research Interests</h2>
      <p class="text-center text-gray-600 dark:text-gray-400 mb-6 max-w-2xl mx-auto">
        My work sits at the intersection of language, reasoning, and human values — building AI systems that are
        more capable, trustworthy, and inclusive.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {researchInterests.map(item => (
          <div class="card">
            <div class="flex items-start gap-4">
              <div class="text-3xl flex-shrink-0">{item.icon}</div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{item.title}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CV Download -->
  <section class="section pb-6">
    <div class="container-narrow">
      <div class="card flex flex-col sm:flex-row items-center justify-center gap-4 py-5">
        <div class="text-center sm:text-left">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Download My CV</h2>
          <p class="text-sm text-gray-600 dark:text-gray-400">Get a copy of my curriculum vitae</p>
        </div>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/cv-short.pdf" download class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium bg-indigo-600 text-white rounded-md hover:bg-indigo-700 transition-colors no-underline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Short CV
          </a>
          <a href="/cv-long.pdf" download class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium bg-gray-200 dark:bg-slate-700 text-gray-800 dark:text-gray-200 rounded-md hover:bg-gray-300 dark:hover:bg-slate-600 transition-colors no-underline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Full CV
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section pb-12">
    <div class="container-narrow">
      <h2 class="section-title text-center">Get In Touch</h2>
      <p class="text-center text-gray-600 dark:text-gray-400 mb-6 max-w-xl mx-auto">
        I'm always open to research collaborations, interesting conversations, and new opportunities.
        Feel free to reach out!
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <a
          href="mailto:haznitrama@kaist.ac.kr"
          class="card flex items-center gap-4 no-underline group"
        >
          <div class="w-10 h-10 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mb-0.5">KAIST Email</p>
            <p class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
              haznitrama@kaist.ac.kr
            </p>
          </div>
        </a>

        <a
          href="mailto:faiz.haznitrama@gmail.com"
          class="card flex items-center gap-4 no-underline group"
        >
          <div class="w-10 h-10 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mb-0.5">Personal Email</p>
            <p class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
              faiz.haznitrama@gmail.com
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Experience {
  role: string;
  org: string;
  location: string;
  period: string;
  description: string;
  projects?: Project[];
}

interface Project {
  name: string;
  description: string;
  tags: string[];
  repo?: string;
  demo?: string;
  paper?: string;
  stars?: string;
}

const experiences: Experience[] = [
  {
    role: 'Lead Researcher',
    org: 'PT. Feedloop Global Teknologi / Feedloop.ai',
    location: 'Indonesia',
    period: 'Dec 2023 — Mar 2026',
    description: 'Lead the research and development team of Feedloop. Improve the current RAG-based pipeline with an increase in performance of up to 20%. Research in making our own LLM, VLM, TTS, AutoML pipeline, and LLM-based apps.',
    projects: [
      {
        name: 'RAG Pipeline Optimization',
        description: 'Improve the current RAG-based pipeline with an increase in performance of up to 20%.',
        tags: ['RAG', 'LLM', 'Pipeline Optimization'],
      },
      {
        name: 'Custom LLM Development',
        description: 'Research and development of custom LLM, VLM, TTS, and AutoML pipelines.',
        tags: ['LLM', 'VLM', 'TTS', 'AutoML'],
      },
      {
        name: 'LLM-based Applications',
        description: 'Develop and deploy LLM-based applications for various use cases.',
        tags: ['LLM', 'Application Development'],
      },
    ],
  },
  {
    role: 'Student Researcher',
    org: 'UILab, KAIST',
    location: 'Daejeon, South Korea',
    period: 'Feb 2024 — Present',
    description: 'Conducting research on multilingual NLP, reasoning under uncertainty, and human-centered AI. Focusing on how language models can better understand and communicate across diverse linguistic contexts.',
    projects: [
      {
        name: 'OLA: Output Language Alignment',
        description: 'Investigating how LLMs handle code-switched prompts and align output language with user expectations. Accepted at ACL 2026 Main Conference.',
        tags: ['Code-Switching', 'LLMs', 'Multilingual NLP'],
        repo: 'https://github.com/faizghifari/ola',
        paper: 'https://arxiv.org/abs/2601.03589',
      },
      {
        name: 'Interpreter-as-Agent MT Evaluation',
        description: 'A framework for evaluating machine translation quality using interpreter-agent paradigms with LLMs.',
        tags: ['Machine Translation', 'LLM Evaluation', 'Python'],
        repo: 'https://github.com/faizghifari/interpreter-agent-eval',
      },
      {
        name: 'Multilingual GPT-BERT for BabyBabelLM',
        description: 'Multilingual pretraining approach for improving low-resource language understanding using BabyBabelLM data.',
        tags: ['Multilingual NLP', 'Pretraining', 'Python'],
        repo: 'https://github.com/faizghifari/babybabellm-gptbert',
        paper: 'https://arxiv.org/abs/2510.10159',
      },
      {
        name: 'Fine-tuning LLMs for Factuality',
        description: 'Exploring techniques to improve factual accuracy in language model outputs through targeted fine-tuning.',
        tags: ['LLMs', 'Factuality', 'Fine-tuning', 'Python'],
        repo: 'https://github.com/faizghifari/factuality-ft',
        stars: '3',
      },
      {
        name: 'Cirebonese Language Research',
        description: 'Corpus building and NLP tool development for Cirebonese, an under-resourced Indonesian language.',
        tags: ['Low-Resource NLP', 'Corpus Building', 'Indonesian Languages'],
        repo: 'https://github.com/faizghifari/cirebonese-exp',
      },
    ],
  },
  {
    role: 'NLP Engineer',
    org: 'PT. Prosa Solusi Cerdas / Prosa.ai',
    location: 'Indonesia',
    period: 'Sep 2019 — Aug 2021',
    description: 'Develop and maintain NLP-based applications/APIs. Conduct experiments in NLP (sentiment analysis, plagiarism detection, info extraction). Create and optimize resource-efficient pipeline for ML model in production.',
    projects: [
      {
        name: 'NLP Applications & APIs',
        description: 'Develop and maintain NLP-based applications and APIs for various clients.',
        tags: ['NLP', 'API Development', 'Production ML'],
      },
      {
        name: 'Sentiment Analysis',
        description: 'Conduct experiments and build sentiment analysis systems.',
        tags: ['Sentiment Analysis', 'NLP'],
      },
      {
        name: 'Plagiarism Detection',
        description: 'Build and optimize plagiarism detection systems.',
        tags: ['Plagiarism Detection', 'NLP'],
      },
      {
        name: 'Information Extraction',
        description: 'Develop information extraction pipelines for various domains.',
        tags: ['Information Extraction', 'NLP'],
      },
    ],
  },
  {
    role: 'Software Engineer Intern',
    org: 'E-Life Solutions Sdn. Bhd.',
    location: 'Malaysia',
    period: 'May 2018 — Aug 2018',
    description: 'Design system architecture for Smart Hospital Asset Management System (SHAMS). Develop server using Node.js, provide communication with hospital embedded devices.',
    projects: [
      {
        name: 'Smart Hospital Asset Management System (SHAMS)',
        description: 'Design system architecture and develop server using Node.js for hospital embedded devices communication.',
        tags: ['Node.js', 'IoT', 'System Architecture'],
        repo: 'https://github.com/faizghifari/smart-hospital-mobileapps',
      },
    ],
  },
];
---

<BaseLayout
  title="Experience — Faiz Ghifari Haznitrama"
  description="Work experience, projects, and research contributions by Faiz Ghifari Haznitrama."
>
  <section class="section">
    <div class="container-narrow">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">Experience</h1>
      <p class="text-gray-600 dark:text-gray-400 mb-10">Work history and projects.</p>

      {experiences.map((exp, idx) => (
        <div class="mb-12 last:mb-0">
          <!-- Experience Header -->
          <div class="flex items-start gap-4 mb-6">
            <div class="timeline-dot mt-1.5"></div>
            <div class="flex-1">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{exp.role}</h2>
              <div class="flex flex-wrap items-center gap-2 mt-1">
                <span class="text-indigo-600 dark:text-indigo-400 font-medium">{exp.org}</span>
                <span class="text-gray-400">&middot;</span>
                <span class="text-sm text-gray-500 dark:text-gray-400">{exp.location}</span>
                <span class="text-gray-400">&middot;</span>
                <span class="tag">{exp.period}</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 mt-3 leading-relaxed">{exp.description}</p>
            </div>
          </div>

          {/* Projects */}
          {exp.projects && exp.projects.length > 0 && (
            <div class="ml-7 pl-6 border-l-2 border-gray-200 dark:border-slate-700 space-y-4">
              {exp.projects.map(project => (
                <div class="card">
                  <div class="flex items-start justify-between mb-2">
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white">{project.name}</h3>
                    {project.stars && (
                      <span class="flex items-center gap-1 text-xs text-yellow-500">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                        {project.stars}
                      </span>
                    )}
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 leading-relaxed">{project.description}</p>
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {project.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                  <div class="flex flex-wrap gap-3">
                    {project.repo && (
                      <a href={project.repo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                        Repository
                      </a>
                    )}
                    {project.demo && (
                      <a href={project.demo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        Demo
                      </a>
                    )}
                    {project.paper && (
                      <a href={project.paper} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                        Paper
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          )}

          {idx < experiences.length - 1 && <div class="divider mt-10 mb-10"></div>}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

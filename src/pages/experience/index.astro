---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Experience {
  role: string;
  org: string;
  location: string;
  period: string;
  description: string;
  projects?: Project[];
}

interface Project {
  name: string;
  description: string;
  tags: string[];
  repo?: string;
  demo?: string;
  paper?: string;
  stars?: string;
}

const experiences: Experience[] = [
  {
    role: 'Ph.D. Student',
    org: 'UILab, KAIST',
    location: 'Daejeon, South Korea',
    period: '2024 — Present',
    description: 'Conducting research on multilingual NLP, reasoning under uncertainty, and human-centered AI. Focusing on how language models can better understand and communicate across diverse linguistic contexts.',
    projects: [
      {
        name: 'OLA: Output Language Alignment',
        description: 'Investigating how LLMs handle code-switched prompts and align output language with user expectations. Accepted at ACL 2026 Main Conference.',
        tags: ['Code-Switching', 'LLMs', 'Multilingual NLP'],
        repo: 'https://github.com/faizghifari/ola',
        paper: 'https://arxiv.org/abs/2601.03589',
      },
      {
        name: 'Interpreter-as-Agent MT Evaluation',
        description: 'A framework for evaluating machine translation quality using interpreter-agent paradigms with LLMs.',
        tags: ['Machine Translation', 'LLM Evaluation', 'Python'],
        repo: 'https://github.com/faizghifari/interpreter-agent-eval',
      },
      {
        name: 'Multilingual GPT-BERT for BabyBabelLM',
        description: 'Multilingual pretraining approach for improving low-resource language understanding using BabyBabelLM data.',
        tags: ['Multilingual NLP', 'Pretraining', 'Python'],
        repo: 'https://github.com/faizghifari/babybabellm-gptbert',
        paper: 'https://arxiv.org/abs/2510.10159',
      },
      {
        name: 'Fine-tuning LLMs for Factuality',
        description: 'Exploring techniques to improve factual accuracy in language model outputs through targeted fine-tuning.',
        tags: ['LLMs', 'Factuality', 'Fine-tuning', 'Python'],
        repo: 'https://github.com/faizghifari/factuality-ft',
        stars: '3',
      },
      {
        name: 'Cirebonese Language Research',
        description: 'Corpus building and NLP tool development for Cirebonese, an under-resourced Indonesian language.',
        tags: ['Low-Resource NLP', 'Corpus Building', 'Indonesian Languages'],
        repo: 'https://github.com/faizghifari/cirebonese-exp',
      },
    ],
  },
  {
    role: 'Research Assistant',
    org: 'KAIST, School of Computing',
    location: 'Daejeon, South Korea',
    period: '2022 — 2023',
    description: 'Conducted research on aspect-based sentiment analysis and dialogue summarization during Master\'s studies at KAIST.',
    projects: [
      {
        name: 'Fix Your Summary',
        description: 'Methods for reducing hallucinations in dialogue summarization tasks. Master\'s thesis work.',
        tags: ['Summarization', 'Hallucination', 'Dialogue NLP'],
        repo: 'https://github.com/faizghifari/fix-your-summary',
        stars: '1',
      },
      {
        name: 'Improved Match-Sum',
        description: 'Improvements to dialogue summarization with match-sum architecture.',
        tags: ['Summarization', 'Dialogue NLP'],
        repo: 'https://github.com/faizghifari/improved-match-sum',
        stars: '1',
      },
      {
        name: 'Summ-Twice',
        description: 'Two-pass summarization approach for improved summary quality.',
        tags: ['Summarization', 'NLP'],
        repo: 'https://github.com/faizghifari/summ-twice',
      },
    ],
  },
  {
    role: 'Researcher / Developer',
    org: 'Independent & Collaborative Projects',
    location: 'Remote',
    period: '2022 — 2024',
    description: 'Worked on various NLP and AI projects including dialogue summarization, hallucination reduction, multilingual benchmarks, and RAG applications.',
    projects: [
      {
        name: 'ID-CSQA',
        description: 'Exploring culturally relevant commonsense QA generation for Indonesian using LLMs. Published at EMNLP 2024 Main Conference.',
        tags: ['Commonsense QA', 'Cultural NLP', 'Indonesian'],
        repo: 'https://github.com/faizghifari/id-csqa',
        paper: 'https://arxiv.org/abs/2402.17302',
      },
      {
        name: 'DocCompanion',
        description: 'RAG-based document companion application powered by LLMs for intelligent document interaction.',
        tags: ['RAG', 'LLM Application', 'Jupyter'],
        repo: 'https://github.com/faizghifari/docompanion',
      },
      {
        name: 'Few-shot Prompting Experiments',
        description: 'Systematic experiments on few-shot prompting strategies across various LLMs and tasks.',
        tags: ['Prompting', 'LLMs', 'Experiments'],
        repo: 'https://github.com/faizghifari/prompting-exp-task',
      },
    ],
  },
];
---

<BaseLayout
  title="Experience — Faiz Ghifari Haznitrama"
  description="Work experience, projects, and research contributions by Faiz Ghifari Haznitrama."
>
  <section class="section">
    <div class="container-narrow">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">Experience</h1>
      <p class="text-gray-600 dark:text-gray-400 mb-10">Work history and projects.</p>

      {experiences.map((exp, idx) => (
        <div class="mb-12 last:mb-0">
          <!-- Experience Header -->
          <div class="flex items-start gap-4 mb-6">
            <div class="timeline-dot mt-1.5"></div>
            <div class="flex-1">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{exp.role}</h2>
              <div class="flex flex-wrap items-center gap-2 mt-1">
                <span class="text-indigo-600 dark:text-indigo-400 font-medium">{exp.org}</span>
                <span class="text-gray-400">&middot;</span>
                <span class="text-sm text-gray-500 dark:text-gray-400">{exp.location}</span>
                <span class="text-gray-400">&middot;</span>
                <span class="tag">{exp.period}</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 mt-3 leading-relaxed">{exp.description}</p>
            </div>
          </div>

          {/* Projects */}
          {exp.projects && exp.projects.length > 0 && (
            <div class="ml-7 pl-6 border-l-2 border-gray-200 dark:border-slate-700 space-y-4">
              {exp.projects.map(project => (
                <div class="card">
                  <div class="flex items-start justify-between mb-2">
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white">{project.name}</h3>
                    {project.stars && (
                      <span class="flex items-center gap-1 text-xs text-yellow-500">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                        {project.stars}
                      </span>
                    )}
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 leading-relaxed">{project.description}</p>
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {project.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                  <div class="flex flex-wrap gap-3">
                    {project.repo && (
                      <a href={project.repo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                        Repository
                      </a>
                    )}
                    {project.demo && (
                      <a href={project.demo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        Demo
                      </a>
                    )}
                    {project.paper && (
                      <a href={project.paper} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                        Paper
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          )}

          {idx < experiences.length - 1 && <div class="divider mt-10 mb-10"></div>}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

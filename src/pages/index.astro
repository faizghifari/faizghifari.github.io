---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';

const recentPapers = [
  {
    title: 'OLA: Output Language Alignment in Code-Switched LLM Interactions',
    authors: 'Juhyun Oh, Haneul Yoo, Faiz Ghifari Haznitrama, Alice Oh',
    venue: 'ACL 2026 Main Conference',
    year: 2026,
    links: { pdf: 'https://arxiv.org/pdf/2601.03589', arxiv: 'https://arxiv.org/abs/2601.03589' },
  },
  {
    title: 'BabyBabelLM: A Multilingual Benchmark of Developmentally Plausible Training Data',
    authors: 'Jaap Jumelet, Abdellah Fourtassi, Akari Haga, et al.',
    venue: 'EACL 2026 Main Conference',
    year: 2026,
    links: { pdf: 'https://arxiv.org/pdf/2510.10159', arxiv: 'https://arxiv.org/abs/2510.10159' },
  },
  {
    title: 'Survey of Cultural Awareness in Language Models: Text and Beyond',
    authors: 'Siddhesh Pawar, Junyeong Park, Jiho Jin, et al.',
    venue: 'Computational Linguistics Journal',
    year: 2025,
    links: { pdf: 'https://arxiv.org/pdf/2411.00860', arxiv: 'https://arxiv.org/abs/2411.00860' },
  },
];

const recentPreprints = [
  {
    title: 'A Neuropsychologically Grounded Evaluation of LLM Cognitive Abilities',
    authors: 'Faiz Ghifari Haznitrama, Faeyza Rishad Ardi, Alice Oh',
    venue: 'arXiv Preprint',
    year: 2026,
    links: { pdf: 'https://arxiv.org/pdf/2603.02540', arxiv: 'https://arxiv.org/abs/2603.02540' },
  },
];

const ongoingResearch = [
  {
    title: 'Interpreter-as-Agent MT Evaluation',
    description: 'Evaluating machine translation quality using interpreter-agent paradigms with LLMs.',
    tags: ['Machine Translation', 'LLM Evaluation'],
    repo: 'https://github.com/faizghifari/interpreter-agent-eval',
  },
  {
    title: 'Multilingual NLP for Low-Resource Languages',
    description: 'Improving NLP for under-resourced language pairs, particularly Indonesian and Southeast Asian languages.',
    tags: ['Multilingual NLP', 'Low-Resource'],
    repo: 'https://github.com/faizghifari/babybabellm-gptbert',
  },
];
---

<BaseLayout
  title="Faiz Ghifari Haznitrama — Ph.D. Student at KAIST"
  description="Personal portfolio of Faiz Ghifari Haznitrama, Ph.D. student at UILab, KAIST. Researcher in multilingual NLP, reasoning, and human-centered AI."
>
  <!-- Header -->
  <section class="section pb-8">
    <div class="container-narrow">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-6 md:gap-8">
        <div class="flex-shrink-0">
          <img
            src="/profile-square.jpg"
            alt="Faiz Ghifari Haznitrama"
            class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover border-2 border-gray-200 dark:border-slate-700"
            loading="eager"
          />
        </div>
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-1">
            Faiz Ghifari Haznitrama
          </h1>
          <p class="text-base text-indigo-600 dark:text-indigo-400 font-medium mb-1">
            Ph.D. Student at <a href="https://uila.kaist.ac.kr/" target="_blank" rel="noopener noreferrer" class="no-underline">UILab</a>, KAIST
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
            Daejeon, South Korea &middot; Multilingual NLP &middot; Reasoning &middot; Human-Centered AI
          </p>
          <div class="flex flex-col sm:flex-row items-center gap-3 mb-3">
            <SocialLinks />
          </div>
          <div class="flex flex-wrap justify-center md:justify-start gap-2">
            <a href="/cv-short.pdf" download class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-indigo-600 text-white rounded-md hover:bg-indigo-700 transition-colors no-underline">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              CV (1-page)
            </a>
            <a href="/cv-long.pdf" download class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-gray-200 dark:bg-slate-700 text-gray-800 dark:text-gray-200 rounded-md hover:bg-gray-300 dark:hover:bg-slate-600 transition-colors no-underline">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Full CV
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Publications -->
  <section class="section pt-4">
    <div class="container-narrow">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Recent Publications</h2>
        <a href="/research" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline">
          View all &rarr;
        </a>
      </div>
      <div class="space-y-4">
        {recentPapers.map((paper) => (
          <div class="card">
            <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-1">{paper.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">{paper.authors}</p>
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="tag">{paper.venue}</span>
              <span class="tag">{paper.year}</span>
            </div>
            <div class="flex flex-wrap gap-2">
              {Object.entries(paper.links).map(([key, url]) => (
                <a href={url} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline">
                  {key}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Preprints -->
  <section class="section pt-4">
    <div class="container-narrow">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Preprints</h2>
        <a href="/research" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline">
          View all &rarr;
        </a>
      </div>
      <div class="space-y-4">
        {recentPreprints.map((paper) => (
          <div class="card">
            <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-1">{paper.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">{paper.authors}</p>
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="tag">{paper.venue}</span>
              <span class="tag">{paper.year}</span>
            </div>
            <div class="flex flex-wrap gap-2">
              {Object.entries(paper.links).map(([key, url]) => (
                <a href={url} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline">
                  {key}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ongoing Research -->
  <section class="section pt-4">
    <div class="container-narrow">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Ongoing Research</h2>
        <a href="/research" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline">
          View all &rarr;
        </a>
      </div>
      <div class="space-y-4">
        {ongoingResearch.map((item) => (
          <div class="card">
            <div class="flex items-start justify-between mb-2">
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">{item.title}</h3>
              <span class="tag">In Progress</span>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-300 mb-3">{item.description}</p>
            <div class="flex flex-wrap gap-2 mb-2">
              {item.tags.map((tag: string) => <span class="tag">{tag}</span>)}
            </div>
            {item.repo && (
              <a href={item.repo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline">
                View Repository &rarr;
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Academic Profiles -->
  <section class="section pt-4">
    <div class="container-narrow">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Academic Profiles</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {[
          { name: 'Google Scholar', url: 'https://scholar.google.com/citations?user=ZH3qXdUAAAAJ&hl=en&authuser=1' },
          { name: 'Semantic Scholar', url: 'https://www.semanticscholar.org/author/Faiz-Ghifari-Haznitrama/2287841290' },
          { name: 'ACL Anthology', url: 'https://aclanthology.org/people/faiz-ghifari-haznitrama/' },
          { name: 'OpenReview', url: 'https://openreview.net/profile?id=%7EFaiz_Ghifari_Haznitrama1' },
          { name: 'DBLP', url: 'https://dblp.org/pid/371/3974' },
          { name: 'ORCID', url: 'https://orcid.org/0009-0005-0342-9261' },
        ].map(profile => (
          <a
            href={profile.url}
            target="_blank"
            rel="noopener noreferrer"
            class="card flex items-center gap-2 py-3 px-4 no-underline group"
          >
            <svg class="w-4 h-4 text-gray-400 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
              {profile.name}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

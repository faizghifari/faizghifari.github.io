---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PaperLinkIcons from '../../components/PaperLinkIcons.astro';
import { formatAuthorList, formatAuthorListWithTruncation } from '../../utils/formatAuthors';

interface Paper {
  title: string;
  authors: string;
  venue: string;
  year: number;
  abstract: string;
  links: Record<string, string>;
}

interface OngoingItem {
  title: string;
  description: string;
  status: string;
  tags: string[];
  repo?: string;
}

const publications: Paper[] = [
  {
    title: 'OLA: Output Language Alignment in Code-Switched LLM Interactions',
    authors: 'Juhyun Oh, Haneul Yoo, Faiz Ghifari Haznitrama, Alice Oh',
    venue: 'ACL 2026 Main Conference',
    year: 2026,
    abstract: 'Code-switching, alternating between languages within a conversation, is natural for multilingual users, yet poses fundamental challenges for large language models (LLMs). When a user code-switches in their prompt to an LLM, they typically do not specify the expected language of the LLM response, and LLMs often fail to align their output language with user expectations.',
    links: { pdf: 'https://arxiv.org/pdf/2601.03589', arxiv: 'https://arxiv.org/abs/2601.03589' },
  },
  {
    title: 'BabyBabelLM: A Multilingual Benchmark of Developmentally Plausible Training Data',
    authors: 'Jaap Jumelet, Abdellah Fourtassi, Akari Haga, Bastian Bunzeck, Bhargav Shandilya, Diana Galvan-Sosa, Faiz Ghifari Haznitrama, Francesca Padovani, Francois Meyer, Hai Hu, Julen Etxaniz, Laurent Prevot, Linyang He, Maria Grandury, Mila Marcheva, Negar Foroutan, Nikitas Theodoropoulos, Pouya Sadeghi, Siyuan Song, Suchir Salhan, Susana Zhou, Yurii Paniv, Ziyin Zhang, Arianna Bisazza, Alex Warstadt, Leshem Choshen',
    venue: 'EACL 2026 Main Conference',
    year: 2026,
    abstract: 'We present BabyBabelLM, a multilingual collection of datasets modeling the language a person observes from birth until they acquire a native language. We curate developmentally plausible pretraining data across multiple languages, enabling research on how language exposure shapes model capabilities.',
    links: { pdf: 'https://arxiv.org/pdf/2510.10159', arxiv: 'https://arxiv.org/abs/2510.10159' },
  },
  {
    title: 'Survey of Cultural Awareness in Language Models: Text and Beyond',
    authors: 'Siddhesh Pawar, Junyeong Park, Jiho Jin, Arnav Arora, Junho Myung, Srishti Yadav, Faiz Ghifari Haznitrama, Inhwa Song, Alice Oh, Isabelle Augenstein',
    venue: 'Computational Linguistics Journal',
    year: 2025,
    abstract: 'Large-scale deployment of large language models (LLMs) in various applications, such as chatbots and virtual assistants, requires LLMs to be culturally sensitive to the user to ensure inclusivity. This survey covers efforts towards incorporating cultural awareness into LLMs across text and multimodal domains.',
    links: { pdf: 'https://arxiv.org/pdf/2411.00860', arxiv: 'https://arxiv.org/abs/2411.00860', doi: 'https://doi.org/10.1162/coli.a.14' },
  },
  {
    title: 'Can LLM Generate Culturally Relevant Commonsense QA Data? Case Study in Indonesian and Sundanese',
    authors: 'Rifki Afina Putri, Faiz Ghifari Haznitrama, Dea Adhista, Alice Oh',
    venue: 'EMNLP 2024 Main Conference',
    year: 2024,
    abstract: 'Large Language Models (LLMs) are increasingly being used to generate synthetic data for training and evaluating models. However, it is unclear whether they can generate a good quality of question answering data that is culturally relevant for under-resourced languages.',
    links: { pdf: 'https://arxiv.org/pdf/2402.17302', arxiv: 'https://arxiv.org/abs/2402.17302', github: 'https://github.com/faizghifari/id-csqa' },
  },
  {
    title: 'Methodologies and Their Comparison in Complex Compound Aspect-Based Sentiment Analysis: A Survey',
    authors: 'Faiz Ghifari Haznitrama, Ho-Jin Choi, Chin-Wan Chung',
    venue: 'AI Open',
    year: 2025,
    abstract: 'A comprehensive survey of methodologies and their comparison in complex compound aspect-based sentiment analysis tasks, covering approaches, datasets, and evaluation metrics.',
    links: { doi: 'https://doi.org/10.1016/j.aiopen.2025.02.002' },
  },
  {
    title: 'Comparative Analysis of Recent Studies on Aspect-Based Sentiment Analysis',
    authors: 'Faiz Ghifari Haznitrama, Ho-Jin Choi, Chin-Wan Chung',
    venue: 'Annual Conference of KIPS',
    year: 2023,
    abstract: 'A comparative analysis of recent studies and approaches in aspect-based sentiment analysis.',
    links: {},
  },
];

const preprints: Paper[] = [
  {
    title: 'A Neuropsychologically Grounded Evaluation of LLM Cognitive Abilities',
    authors: 'Faiz Ghifari Haznitrama, Faeyza Rishad Ardi, Alice Oh',
    venue: 'arXiv Preprint',
    year: 2026,
    abstract: 'Large language models (LLMs) exhibit a unified "general factor" of capability across 10 benchmarks, a finding confirmed by our factor analysis of 156 models, yet they still struggle with simple, trivial tasks. We adapt neuropsychological tests to evaluate the cognitive mechanisms of LLMs, providing a grounded framework for understanding model capabilities.',
    links: { pdf: 'https://arxiv.org/pdf/2603.02540', arxiv: 'https://arxiv.org/abs/2603.02540' },
  },
];

const theses: Paper[] = [
  {
    title: 'Master\'s Thesis: Addressing Hallucination in Abstractive Dialogue Summarization via Span Identification and Correction',
    authors: 'Faiz Ghifari Haznitrama, Ho-Jin Choi, Chin-Wan Chung',
    venue: 'KAIST, School of Computing',
    year: 2023,
    abstract: 'We propose a post-processing approach to address hallucination in abstractive dialogue summarization through span identification and correction techniques, improving factual consistency of generated summaries.',
    links: { pdf: 'https://openreview.net/pdf?id=cpnJu16ORV', openreview: 'https://openreview.net/forum?id=cpnJu16ORV', github: 'https://github.com/faizghifari/fix-your-summary' },
  },
  {
    title: 'Bachelor\'s Thesis: Indonesian Qur\'an Verse Extractor',
    authors: 'Faiz Ghifari Haznitrama',
    venue: 'Institut Teknologi Bandung',
    year: 2019,
    abstract: 'Build a system to find Qur\'an verses related to given Indonesian text by measuring semantic similarity.',
    links: { pdf: 'https://digilib.itb.ac.id/gdl/view/43425/quran?rows=9&per_page=5', github: 'https://github.com/faizghifari/indonesian-quran-verse-extractor' },
  },
];

const ongoing: OngoingItem[] = [
  {
    title: 'Interpreter-as-Agent MT Evaluation',
    description: 'Developing frameworks for evaluating machine translation quality using interpreter-agent paradigms with LLMs.',
    status: 'In Progress',
    tags: ['Machine Translation', 'LLM Evaluation'],
    repo: 'https://github.com/faizghifari/interpreter-agent-eval',
  },
  {
    title: 'Multilingual NLP for Low-Resource Languages',
    description: 'Exploring approaches to improve NLP performance for under-resourced language pairs, particularly Indonesian and Southeast Asian languages.',
    status: 'In Progress',
    tags: ['Multilingual NLP', 'Low-Resource'],
    repo: 'https://github.com/faizghifari/babybabellm-gptbert',
  },
  {
    title: 'Reasoning Under Uncertainty in LLMs',
    description: 'Investigating how large language models handle uncertain or ambiguous information during reasoning tasks.',
    status: 'In Progress',
    tags: ['Reasoning', 'LLMs', 'Uncertainty'],
  },
];
---

<BaseLayout
  title="Research — Faiz Ghifari Haznitrama"
  description="Research publications, preprints, and ongoing work by Faiz Ghifari Haznitrama at UILab, KAIST."
>
  <section class="section">
    <div class="container-narrow">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">Research</h1>
      <p class="text-gray-600 dark:text-gray-400 mb-8">Publications, preprints, and ongoing research projects.</p>

      <div class="flex gap-1 mb-8 border-b border-gray-200 dark:border-slate-700" id="tabs">
        <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-indigo-600 dark:border-indigo-400 text-indigo-600 dark:text-indigo-400 transition-colors" data-tab="publications">
          Publications ({publications.length})
        </button>
        <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors" data-tab="preprints">
          Preprints ({preprints.length})
        </button>
        <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors" data-tab="ongoing">
          Ongoing ({ongoing.length})
        </button>
      </div>

      <!-- Publications Tab -->
      <div id="tab-publications" class="tab-content">
        <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-4">Peer-Reviewed Publications</h3>
        <div class="space-y-4">
          {publications.map((paper: Paper) => (
            <div class="card">
              <h4 class="text-base font-semibold text-gray-900 dark:text-white mb-1">{paper.title}</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-2" set:html={paper.title.includes('BabyBabelLM') ? formatAuthorListWithTruncation(paper.authors, true) : formatAuthorList(paper.authors)}></p>
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="tag">{paper.venue}</span>
                <span class="tag">{paper.year}</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 leading-relaxed">{paper.abstract}</p>
              {Object.keys(paper.links).length > 0 && <PaperLinkIcons links={paper.links} />}
            </div>
          ))}
        </div>
        <div class="mt-8">
          <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-4">Theses</h3>
          <div class="space-y-4">
            {theses.map((paper: Paper) => (
              <div class="card">
                <h4 class="text-base font-semibold text-gray-900 dark:text-white mb-1">{paper.title}</h4>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-2" set:html={formatAuthorList(paper.authors)}></p>
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span class="tag">{paper.venue}</span>
                  <span class="tag">{paper.year}</span>
                </div>
                <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 leading-relaxed">{paper.abstract}</p>
                {Object.keys(paper.links).length > 0 && <PaperLinkIcons links={paper.links} />}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Preprints Tab -->
      <div id="tab-preprints" class="tab-content hidden">
        <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-4">Preprints & Working Papers</h3>
        <div class="space-y-4">
          {preprints.map((paper: Paper) => (
            <div class="card">
              <h4 class="text-base font-semibold text-gray-900 dark:text-white mb-1">{paper.title}</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-2" set:html={formatAuthorList(paper.authors)}></p>
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="tag">{paper.venue}</span>
                <span class="tag">{paper.year}</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 leading-relaxed">{paper.abstract}</p>
              {Object.keys(paper.links).length > 0 && <PaperLinkIcons links={paper.links} />}
            </div>
          ))}
        </div>
      </div>

      <!-- Ongoing Tab -->
      <div id="tab-ongoing" class="tab-content hidden">
        <div class="space-y-4">
          {ongoing.map((item: OngoingItem) => (
            <div class="card">
              <div class="flex items-start justify-between mb-2">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{item.title}</h3>
                <span class="tag">{item.status}</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 leading-relaxed">{item.description}</p>
              <div class="flex flex-wrap gap-2 mb-3">
                {item.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
              {item.repo && (
                <a href={item.repo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline">
                  View Repository &rarr;
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.tab-btn');
      const contents = document.querySelectorAll('.tab-content');
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          tabs.forEach(t => {
            t.classList.remove('border-indigo-600', 'dark:border-indigo-400', 'text-indigo-600', 'dark:text-indigo-400');
            t.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
          });
          tab.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
          tab.classList.add('border-indigo-600', 'dark:border-indigo-400', 'text-indigo-600', 'dark:text-indigo-400');
          contents.forEach(c => c.classList.add('hidden'));
          document.getElementById(`tab-${target}`)?.classList.remove('hidden');
        });
      });
    });
  </script>
</BaseLayout>
